{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PIO: Build",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\python3\\python.exe",
      "args": [
        "-m",
        "platformio",
        "run",
        "--project-dir",
        "${workspaceFolder}\\src"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "PIO: Upload",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\python3\\python.exe",
      "args": [
        "-m",
        "platformio",
        "run",
        "-t",
        "upload",
        "--project-dir",
        "${workspaceFolder}\\src"
      ],
      "problemMatcher": []
    },
    {
      "label": "PIO: Upload (COM3)",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\python3\\python.exe",
      "args": [
        "-m",
        "platformio",
        "run",
        "-t",
        "upload",
        "--project-dir",
        "${workspaceFolder}\\src",
        "--upload-port",
        "COM3"
      ],
      "problemMatcher": []
    },
    {
      "label": "PIO: Monitor (COM3, 115200)",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\python3\\python.exe",
      "args": [
        "-m",
        "platformio",
        "device",
        "monitor",
        "--port",
        "COM3",
        "--baud",
        "115200"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "PIO: Clean",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\python3\\python.exe",
      "args": [
        "-m",
        "platformio",
        "run",
        "-t",
        "clean",
        "--project-dir",
        "${workspaceFolder}\\src"
      ],
      "problemMatcher": []
    }
  ]
}
